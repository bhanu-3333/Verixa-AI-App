# Application
APP_NAME=Verixa AI
HOST=127.0.0.1
PORT=8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=verixa_db

# Security
SECRET_KEY=your-secret-key-here-change-this

# AI Engine (Phase 4)
AI_ENGINE_URL=http://localhost:5000
